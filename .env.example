# Your publishable key from TONE3000 Settings → API Keys
VITE_PUBLISHABLE_KEY=t3k_pub_your_key_here

# Redirect URI for the OAuth flow.
# Nothing *serves* this URL in an Electron app — the main process intercepts the
# navigation to it and reads the authorization code off the query string (see
# src/main/index.ts). It must still be registered in your API key's allowed
# redirect URIs. Localhost origins are auto-allowed during development.
VITE_REDIRECT_URI=http://localhost:3001/callback

# Optional: override the API domain (default https://www.tone3000.com)
# VITE_T3K_API_DOMAIN=http://localhost:3000
